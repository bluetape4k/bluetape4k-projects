<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency Check false-positive suppressions.
        Add entries here when a CVE is a confirmed false positive or
        has been explicitly accepted via risk review.

        Format:
        <suppress>
            <notes>Reason for suppression + ticket/date</notes>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>

        Or by file path:
        <suppress>
            <filePath regex="true">.*\/h2-.*\.jar</filePath>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>
    -->
</suppressions>
